{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/hooks/scope-guard.sh\"", "timeout": 15 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/hooks/reversibility-guard.sh\"", "timeout": 15 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/hooks/finish-the-work.sh\"", "timeout": 15 },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/hooks/decision-guard.sh\"", "timeout": 15 },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/hooks/claim-guard.sh\"", "timeout": 20 }
        ]
      }
    ]
  }
}
